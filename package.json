{
  "homepage": "https://xlvk.github.io/graphql/",
  "name": "graphql-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"vite\" \"tsc -w\" \"func start --typescript\"",
    "build": "vite build && tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "test": "echo \"No tests yet...\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^5.2.6"
  },
  "dependencies": {
    "@graphiql/toolkit": "^0.9.1",
    "apollo-server": "^3.13.0",
    "axios": "^1.7.2",
    "buffer": "^6.0.3",
    "chart.js": "^4.4.3",
    "d3": "^7.9.0",
    "graphiql": "^3.3.1",
    "graphql": "^16.9.0",
    "js-cookies": "^1.0.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "toastify-js": "^1.12.0"
  },
  "include": [
    "./src/**/*"
  ]
}
